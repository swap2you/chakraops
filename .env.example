# Environment variables for ChakraOps
# Copy this file to .env and fill in your values

# Application settings
APP_NAME=ChakraOps
APP_ENV=development
DEBUG=true

# API keys (if needed)
# API_KEY=your_api_key_here

# Database (if needed)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=chakraops
# DB_USER=your_user
# DB_PASSWORD=your_password
