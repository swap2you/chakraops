# ChakraOps Configuration Example
# Copy this file to config.yaml and customize as needed
# Central configuration for all pipeline and data provider settings

app:
  name: ChakraOps
  env: development
  debug: true

# ThetaData Terminal v3 configuration
theta:
  # Base URL for Theta Terminal REST API (v3 endpoints)
  # The terminal must be running locally. Do NOT include /v3 suffix here.
  base_url: "http://127.0.0.1:25503/v3"
  
  # Request timeout in seconds
  timeout: 10.0
  
  # Enable fallback to latest snapshot when live data is unavailable
  # When true: if Theta Terminal is unreachable, load latest decision JSON from out/
  # When false: fail immediately if live data is unavailable
  fallback_enabled: true
  
  # Endpoint selection for options data:
  # - "ohlc_per_strike": Call /option/snapshot/ohlc for each strike (default, most compatible)
  # - "quote_per_strike": Call /option/snapshot/quote for each strike
  # - "ohlc_bulk": Call /option/snapshot/ohlc without strike param (all strikes at once, faster)
  # - "quote_bulk": Call /option/snapshot/quote without strike param (all strikes at once)
  # - "auto": Try bulk first, fall back to per-strike if bulk returns no data
  # Run `python scripts/test_theta_chain.py AAPL` to determine which works for your subscription.
  endpoint: "ohlc_per_strike"
  
  # Maximum strikes per expiration when using per-strike modes
  # Limits to near-the-money strikes to avoid slow API calls
  # Set higher for more coverage, lower for faster execution
  strike_limit: 30

# Snapshot retention settings
snapshots:
  # Number of days to retain decision_*.json files
  # Files older than this will be deleted during cleanup
  # Only one file per day is kept (newest)
  retention_days: 7
  
  # Maximum number of decision files to keep regardless of age
  # Set to 0 to disable (only use retention_days)
  max_files: 30
  
  # Output directory for decision files
  output_dir: "out"

# Realtime mode settings (--realtime flag in run_and_save.py)
realtime:
  # Refresh interval in seconds between pipeline runs
  # Recommended: 60 for production, 300 for testing
  refresh_interval: 60
  
  # Market close time (HH:MM:SS) when realtime mode should stop
  # Uses local time. Default is 16:00:00 EST (US market close)
  end_time: "16:00:00"

# Logging configuration
logging:
  level: INFO
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
