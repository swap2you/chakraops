# ChakraOps Configuration Example
# Copy this file to config.yaml and customize as needed
# Central configuration for all pipeline and data provider settings

app:
  name: ChakraOps
  env: development
  debug: true

# ThetaData Terminal v3 configuration
theta:
  # Base URL for Theta Terminal REST API (v3 endpoints)
  # The terminal must be running locally. Do NOT include /v3 suffix here.
  base_url: "http://127.0.0.1:25503/v3"
  
  # Request timeout in seconds
  timeout: 10.0
  
  # Enable fallback to latest snapshot when live data is unavailable
  # When true: if Theta Terminal is unreachable, load latest decision JSON from out/
  # When false: fail immediately if live data is unavailable
  fallback_enabled: true
  
  # Endpoint selection for options data:
  # RECOMMENDED: Use "quote_bulk" or "ohlc_bulk" for Standard subscriptions
  # - "quote_bulk": Fetch all contracts per expiration via /option/snapshot/quote (RECOMMENDED, fastest)
  # - "ohlc_bulk": Fetch all contracts per expiration via /option/snapshot/ohlc (includes OHLC data)
  # - "auto": Try quote_bulk first, then ohlc_bulk, then fall back to per-strike
  # DEPRECATED (may not work for Standard subscriptions):
  # - "ohlc_per_strike": Call /option/snapshot/ohlc for each strike (slow, may return empty)
  # - "quote_per_strike": Call /option/snapshot/quote for each strike (slow, may return empty)
  # Run `python scripts/test_theta_chain.py AAPL` to test which endpoint works.
  endpoint: "quote_bulk"
  
  # Maximum strikes per expiration when using per-strike modes (ignored for bulk)
  strike_limit: 30

# Snapshot retention settings
snapshots:
  # Number of days to retain decision_*.json files
  # Files older than this will be deleted during cleanup
  # Only one file per day is kept (newest)
  retention_days: 7
  
  # Maximum number of decision files to keep regardless of age
  # Set to 0 to disable (only use retention_days)
  max_files: 30
  
  # Output directory for decision files
  output_dir: "out"

# Realtime mode settings (--realtime flag in run_and_save.py)
realtime:
  # Refresh interval in seconds between pipeline runs
  # Recommended: 60 for production, 300 for testing
  refresh_interval: 60
  
  # Market close time (HH:MM:SS) when realtime mode should stop
  # Uses local time. Default is 16:00:00 EST (US market close)
  end_time: "16:00:00"

# Optional guardrails
guardrails:
  # Minimum stock price to avoid penny stocks (enforced in universe filter).
  min_stock_price: 10.0
  # Max trades per sector for diversification (advisory; sector data required).
  max_trades_per_sector: 3
  # Advisory stop-loss: exit if underlying drops this % below strike (manual/broker).
  stop_loss_pct: null
  # Advisory profit target: close at this % of max profit (e.g. 0.50 = 50%).
  profit_target_pct: null

# Logging configuration
logging:
  level: INFO
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
