# ChakraOps Configuration
# Copy this file to config.yaml and customize as needed

app:
  name: ChakraOps
  env: development
  debug: true

# ThetaData Terminal v3 configuration
theta:
  # Base URL for Theta Terminal REST API (v3 endpoints)
  # The terminal must be running locally.
  base_url: "http://127.0.0.1:25503/v3"
  
  # Request timeout in seconds
  timeout: 10.0
  
  # Enable fallback to latest snapshot when live data is unavailable
  # When true: if Theta Terminal is unreachable or returns NOT_FOUND, load latest decision JSON
  # When false: fail immediately if live data is unavailable
  fallback_enabled: true

# Snapshot retention settings
snapshots:
  # Number of days to retain decision_*.json files
  retention_days: 7
  
  # Maximum number of decision files to keep regardless of age
  # Set to 0 to disable (only use retention_days)
  max_files: 30
  
  # Output directory for decision files
  output_dir: "out"

# Logging configuration
logging:
  level: INFO
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Example sections for future use
# database:
#   host: localhost
#   port: 5432
#   name: chakraops
